# ================================
# 서버 배포용 환경변수 설정
# ================================

# Spring
SPRING_PROFILES_ACTIVE=prod

# JWT 서명 키 (최소 32자 이상 권장)
JWT_SECRET_KEY=your_jwt_secret_here

# Docker Hub (이미지 pull용 계정)
DOCKERHUB_USERNAME=your_dockerhub_id

# Database (튜터님 서버 3 - 외부 DB 주소)
DB_HOST=your_db_host_ip
DB_PORT=3306
DB_NAME=app_db
DB_USER=app_user
DB_PASSWORD=your_password_here

# Redis (튜터님 서버 3)
REDIS_HOST=your_redis_host_ip
REDIS_PORT=6379

# ================================
# 아래 항목은 GitHub Secrets에서 관리
# ================================
# DOCKERHUB_TOKEN=
# SSH_HOST=
# SSH_PORT=
# SSH_USERNAME=
# SSH_PRIVATE_KEY=
# REVIEW_SERVER_URL=
# REVIEW_SECRET=
